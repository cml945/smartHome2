# ============================================================
# 智能家居人体位置感知灯控系统 - 环境变量配置
# 复制此文件为 .env 并填写实际值：cp .env.example .env
# ============================================================

# ---------- 小米账号 ----------
# 通过 go2rtc WebUI 登录小米账号后可获取
XIAOMI_USER_ID=your_xiaomi_user_id
XIAOMI_REGION=cn

# ---------- 摄像头配置 ----------
# 每台摄像头需要：局域网 IP、设备 ID (did)、设备型号 (model)
# 通过 go2rtc WebUI -> Add -> Xiaomi 可自动发现

# 客厅摄像头
CAM_LIVING_ROOM_IP=192.168.1.101
CAM_LIVING_ROOM_DID=your_device_id_1
CAM_LIVING_ROOM_MODEL=isa.camera.hlc7

# 卧室摄像头
CAM_BEDROOM_IP=192.168.1.102
CAM_BEDROOM_DID=your_device_id_2
CAM_BEDROOM_MODEL=isa.camera.hlc7

# 书房摄像头
CAM_STUDY_IP=192.168.1.103
CAM_STUDY_DID=your_device_id_3
CAM_STUDY_MODEL=isa.camera.hlc7

# ---------- 网络配置 ----------
# Mac Mini 的局域网 IP（HA Frigate 集成需要用此 IP 访问 Frigate API）
MAC_HOST_IP=192.168.1.100

# Home Assistant 的 IP（UTM 虚拟机的桥接 IP）
HA_IP=192.168.1.200

# MQTT 端口（HA Mosquitto Add-on 默认端口）
MQTT_PORT=1883

# MQTT 认证（如果 Mosquitto 配置了用户名密码）
MQTT_USER=
MQTT_PASSWORD=

# ---------- Frigate 配置 ----------
FRIGATE_PORT=8971
FRIGATE_RTSP_PORT=8554
FRIGATE_GO2RTC_PORT=1984
FRIGATE_WEBRTC_PORT=8555

# Frigate 存储路径（录像和快照的保存位置）
FRIGATE_STORAGE_PATH=/Users/Shared/frigate-storage

# ---------- Detector 配置 ----------
# Apple Silicon Detector 的 ZeroMQ 端口
DETECTOR_ZMQ_PORT=5555
# 检测模型
DETECTOR_MODEL=yolov9-320-t

# ---------- Home Assistant ----------
# HA 长期访问令牌（HA -> 用户头像 -> 长期访问令牌 -> 创建）
HA_TOKEN=your_ha_long_lived_access_token
