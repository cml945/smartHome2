# ============================================================
# 智能家居人体位置感知灯控系统 - 环境变量配置
# 复制此文件为 .env 并填写实际值：cp .env.example .env
# ============================================================

# ---------- 小米账号 ----------
# 获取方法：部署 go2rtc 后，打开 WebUI (http://localhost:1984)
#           点击 Add -> Xiaomi -> 登录小米账号，界面会显示 user_id
XIAOMI_USER_ID=your_xiaomi_user_id
XIAOMI_REGION=cn

# ---------- 摄像头配置 ----------
# 获取方法：go2rtc WebUI 登录小米账号后会自动发现摄像头，
#           显示每台摄像头的 IP、did、model 参数
# 如有多台摄像头，参照此格式添加（同时需修改 frigate/config.example.yml）

# 书房摄像头（小米智能摄像机云台版Pro）
CAM_STUDY_IP=192.168.31.xxx
CAM_STUDY_DID=your_device_id
CAM_STUDY_MODEL=xiaomi.camera.ptz

# ---------- 网络配置 ----------
# Mac Mini 的局域网 IP（HA Frigate 集成需要用此 IP 访问 Frigate API）
MAC_HOST_IP=192.168.31.233

# Home Assistant 的 IP（UTM 虚拟机的桥接 IP）
HA_IP=192.168.31.224

# MQTT 端口（HA Mosquitto Add-on 默认端口）
MQTT_PORT=1883

# MQTT 认证（Mosquitto Add-on 安装后需设置用户名密码）
MQTT_USER=
MQTT_PASSWORD=

# ---------- Frigate 配置 ----------
FRIGATE_PORT=8971
FRIGATE_RTSP_PORT=8554
FRIGATE_GO2RTC_PORT=1984
FRIGATE_WEBRTC_PORT=8555

# Frigate 存储路径（录像和快照的保存位置）
FRIGATE_STORAGE_PATH=/Users/Shared/frigate-storage

# ---------- Detector 配置 ----------
# Apple Silicon Detector 的 ZeroMQ 端口
DETECTOR_ZMQ_PORT=5555
# 检测模型
DETECTOR_MODEL=yolov9-320-t

# ---------- Home Assistant ----------
# 获取方法：HA 界面 -> 左下角用户头像 -> 安全 -> 长期访问令牌 -> 创建令牌
HA_TOKEN=your_ha_long_lived_access_token
